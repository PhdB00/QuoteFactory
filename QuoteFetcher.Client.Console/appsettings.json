{
  "QuoteApiSettings": 
  {
    "ApiHost": "http://localhost:5074/",
    "MaxConcurrentApiCalls" : 5,
    "MaxRetryOnDuplicate" : 10,
    "CacheExpireAfterMinutes" : 15
  },
  "Logging": {
    "LogLevel": {
      "Default": "Critical", 
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "IncludeScopes": true
      }
    }
  }
}